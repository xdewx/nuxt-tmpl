DATABASE_URL=file:./data/dev.db

BASE_URL=http://localhost:3000

# Auth provider: clerk | better-auth | supabase | (empty = disabled)
# NUXT_PUBLIC_AUTH_PROVIDER=

# === Clerk — uncomment and set when AUTH_PROVIDER=clerk ===
# NUXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
# NUXT_CLERK_SECRET_KEY=

# === Better-Auth — uncomment and set when AUTH_PROVIDER=better-auth ===
# BETTER_AUTH_SECRET=
# BETTER_AUTH_URL=http://localhost:3000

# === Supabase — uncomment and set when AUTH_PROVIDER=supabase ===
# NUXT_PUBLIC_SUPABASE_URL=
# NUXT_PUBLIC_SUPABASE_ANON_KEY=
# SUPABASE_DB_URL=postgresql://supabase_admin:password@localhost:5432/postgres?sslmode=disable
