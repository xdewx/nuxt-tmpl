DATABASE_URL=file:./data/dev.db

BASE_URL=http://localhost:3000

# Auth provider: clerk | better-auth | (empty = disabled)
# Nuxt runtime config convention (takes priority)
NUXT_PUBLIC_AUTH_PROVIDER=clerk
# Alternative, also supported
# AUTH_PROVIDER=clerk

# clerk (only needed when AUTH_PROVIDER=clerk)
NUXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
NUXT_CLERK_SECRET_KEY=

# better-auth (only needed when AUTH_PROVIDER=better-auth)
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000
